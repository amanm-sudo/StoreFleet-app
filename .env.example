# Copy this file to backend/config/uat.env and fill in your values

PORT=3000
mongoURI=mongodb://127.0.0.1:27017/storefleet

JWT_Secret=your_jwt_secret_here
JWT_Expire=1d
COOKIE_EXPIRES_IN=1

# Gmail SMTP credentials for sending welcome/reset emails
STORFLEET_SMPT_MAIL=your_gmail@gmail.com
STORFLEET_SMPT_MAIL_PASSWORD=your_gmail_app_password
SMPT_SERVICE=gmail
